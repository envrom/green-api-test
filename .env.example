# GREEN-API base URL (do not add trailing slash)
GREEN_API_BASE_URL=https://api.green-api.com

# Your GREEN-API instance credentials
# Find them in your GREEN-API personal cabinet
GREEN_API_ID_INSTANCE=your_instance_id
GREEN_API_TOKEN_INSTANCE=your_token_instance

# Target WhatsApp chat ID for sending test messages
# Format: <country_code><phone_number>@c.us  (e.g. 79001234567@c.us)
GREEN_API_CHAT_ID=79001234567@c.us

# A syntactically invalid chat ID used in negative tests
GREEN_API_INVALID_CHAT_ID=invalid-chat-id

# Number of messages to fetch from getChatHistory
GREEN_API_HISTORY_COUNT=20

# Polling configuration for e2e message flow test
GREEN_API_POLL_INTERVAL_MS=3000
GREEN_API_POLL_TIMEOUT_MS=60000

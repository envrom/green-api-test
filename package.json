{
  "name": "green-api-test-framework",
  "version": "1.0.0",
  "description": "QA Automation mini-framework for GREEN-API — Jest + TypeScript",
  "private": true,
  "scripts": {
    "test": "jest",
    "test:api": "jest --testPathPattern=tests/api",
    "test:watch": "jest --watch",
    "test:verbose": "jest --verbose",
    "test:coverage": "jest --coverage",
    "test:selenium": "jest --config jest.selenium.config.ts"
  },
  "dependencies": {
    "axios": "^1.7.2",
    "dotenv": "^16.4.5"
  },
  "devDependencies": {
    "@types/jest": "^29.5.12",
    "@types/node": "^20.14.2",
    "@types/selenium-webdriver": "^4.35.5",
    "chromedriver": "^145.0.6",
    "jest": "^29.7.0",
    "selenium-webdriver": "^4.41.0",
    "ts-jest": "^29.1.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
